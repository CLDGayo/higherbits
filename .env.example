# Required for Phase 2 claymorphism-3d-redesign asset generation (Gemini image model).
GEMINI_API_KEY=
# Optional. Overrides the ops asset-gen default image model (gemini-3-pro-image-preview).
# Set to a current image model id if the default is retired (script fails fast on 404/NOT_FOUND).
GEMINI_IMAGE_MODEL=
